<html>
<head>
<title>Open Field Studio - Setup</title>
<HTA:APPLICATION
    ID="OFSSetup"
    APPLICATIONNAME="Open Field Studio Setup"
    BORDER="thin"
    BORDERSTYLE="normal"
    CAPTION="yes"
    ICON="icon.ico"
    MAXIMIZEBUTTON="no"
    MINIMIZEBUTTON="yes"
    SHOWINTASKBAR="yes"
    SINGLEINSTANCE="yes"
    SYSMENU="yes"
    SCROLL="no"
    WINDOWSTATE="normal"
/>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Segoe UI',sans-serif;background:#2A2A32;color:#fff;overflow:hidden;}
.header{background:linear-gradient(135deg,#D97706,#F59E0B,#EA580C);padding:30px;text-align:center;}
.header h1{font-size:22px;font-weight:700;margin-top:10px;}
.header p{font-size:12px;opacity:.9;margin-top:4px;}
.logo{width:56px;height:56px;margin:0 auto;}
.logo svg{width:100%;height:100%;}
.body{padding:24px 30px;}
.features{display:flex;flex-wrap:wrap;gap:6px;margin:16px 0 20px;}
.feat{background:rgba(255,255,255,.06);border-radius:6px;padding:6px 12px;font-size:12px;color:#d4d4d8;}
.options{margin:16px 0;}
.opt{display:flex;align-items:center;gap:8px;padding:6px 0;font-size:13px;color:#d4d4d8;}
.opt input{width:16px;height:16px;accent-color:#D97706;}
.path{background:#1e1e26;border:1px solid rgba(255,255,255,.1);border-radius:6px;padding:10px 14px;font-family:Consolas,monospace;font-size:12px;color:#D97706;margin:12px 0;}
.btn{display:block;width:100%;padding:14px;border:none;border-radius:8px;font-family:'Segoe UI',sans-serif;font-size:15px;font-weight:600;cursor:pointer;margin-top:16px;text-align:center;}
.btn-primary{background:#D97706;color:#fff;}
.btn-primary:hover{background:#EA580C;}
.progress{display:none;margin:20px 0;}
.progress-track{width:100%;height:6px;background:#1e1e26;border-radius:99px;overflow:hidden;}
.progress-fill{height:100%;background:linear-gradient(90deg,#D97706,#F59E0B);border-radius:99px;width:0%;transition:width .4s;}
.status{font-size:12px;color:#A1A1AA;text-align:center;margin-top:10px;}
.success{display:none;text-align:center;padding:20px 0;}
.success .check{width:60px;height:60px;background:rgba(22,163,74,.15);border-radius:50%;line-height:60px;font-size:30px;margin:0 auto 14px;}
.success h2{font-size:18px;margin-bottom:6px;}
.success p{color:#A1A1AA;font-size:13px;}
.footer{padding:10px 30px;text-align:center;font-size:10px;color:#52525b;border-top:1px solid rgba(255,255,255,.06);}
</style>
<script language="VBScript">
Sub Window_OnLoad
    window.resizeTo 460, 580
    Dim w, h, sl, st
    w = 460
    h = 580
    sl = (screen.width - w) / 2
    st = (screen.height - h) / 2
    window.moveTo sl, st
End Sub

Sub RunInstall
    Dim fso, shell, desktop, startmenu, sc
    Set fso = CreateObject("Scripting.FileSystemObject")
    Set shell = CreateObject("WScript.Shell")

    ' Get paths
    Dim appPath
    appPath = fso.GetParentFolderName(document.location.pathname)
    If Left(appPath, 1) = "\" Then appPath = Mid(appPath, 2)

    ' Show progress
    document.getElementById("step-main").style.display = "none"
    document.getElementById("step-progress").style.display = "block"

    ' Step 1: Desktop shortcut
    updateProgress 20, "Bureaublad snelkoppeling aanmaken..."
    If document.getElementById("opt-desktop").checked Then
        desktop = shell.SpecialFolders("Desktop")
        Set sc = shell.CreateShortcut(desktop & "\Open Field Studio.lnk")
        sc.TargetPath = appPath & "\index.html"
        sc.WorkingDirectory = appPath
        sc.Description = "Open Field Studio - Inspectie, Oplevering & Kwaliteitsborging"
        sc.IconLocation = appPath & "\icon.ico"
        sc.Save
    End If

    ' Step 2: Start Menu shortcut
    updateProgress 50, "Startmenu snelkoppeling aanmaken..."
    If document.getElementById("opt-startmenu").checked Then
        startmenu = shell.SpecialFolders("Programs")
        Set sc = shell.CreateShortcut(startmenu & "\Open Field Studio.lnk")
        sc.TargetPath = appPath & "\index.html"
        sc.WorkingDirectory = appPath
        sc.Description = "Open Field Studio - Inspectie, Oplevering & Kwaliteitsborging"
        sc.IconLocation = appPath & "\icon.ico"
        sc.Save
    End If

    ' Step 3: Done
    updateProgress 100, "Installatie voltooid!"

    ' Show success after short delay
    window.setTimeout "ShowSuccess", 800
End Sub

Sub updateProgress(pct, msg)
    document.getElementById("prog-fill").style.width = pct & "%"
    document.getElementById("prog-status").innerText = msg
End Sub

Sub ShowSuccess
    document.getElementById("step-progress").style.display = "none"
    document.getElementById("step-success").style.display = "block"
End Sub

Sub OpenApp
    Dim fso, shell, appPath
    Set fso = CreateObject("Scripting.FileSystemObject")
    Set shell = CreateObject("WScript.Shell")
    appPath = fso.GetParentFolderName(document.location.pathname)
    If Left(appPath, 1) = "\" Then appPath = Mid(appPath, 2)
    shell.Run """" & appPath & "\index.html"""
    window.close
End Sub
</script>
</head>
<body>
<div class="header">
    <div class="logo">
        <svg viewBox="0 0 32 32" fill="none">
            <path d="M16 2L4 9v14l12 7 12-7V9L16 2z" fill="rgba(255,255,255,.15)" stroke="#fff" stroke-width="1.5"/>
            <path d="M4 9l12 7v14" stroke="#fff" stroke-width="1.5"/>
            <path d="M28 9l-12 7" stroke="#fff" stroke-width="1.5"/>
            <path d="M16 2l-6 3.5L16 9l6-3.5L16 2z" fill="#fff" opacity=".4"/>
        </svg>
    </div>
    <h1>Open Field Studio</h1>
    <p>Inspectie, Oplevering & Kwaliteitsborging</p>
</div>

<div class="body">
    <!-- Main step -->
    <div id="step-main">
        <div class="features">
            <span class="feat">Tickets & gebreken</span>
            <span class="feat">Checklist-inspecties</span>
            <span class="feat">Oplevering & PV</span>
            <span class="feat">Energielabel</span>
            <span class="feat">Monument inspectie</span>
            <span class="feat">NEN 2767</span>
            <span class="feat">Dashboard</span>
            <span class="feat">Camera</span>
            <span class="feat">Offline</span>
        </div>

        <div class="path">W:\Open Field Studio\</div>

        <div class="options">
            <label class="opt"><input type="checkbox" id="opt-desktop" checked> Snelkoppeling op bureaublad</label>
            <label class="opt"><input type="checkbox" id="opt-startmenu" checked> Toevoegen aan Startmenu</label>
        </div>

        <button class="btn btn-primary" onclick="RunInstall">Installeren</button>
    </div>

    <!-- Progress step -->
    <div id="step-progress" class="progress">
        <div class="progress-track"><div class="progress-fill" id="prog-fill"></div></div>
        <p class="status" id="prog-status">Voorbereiden...</p>
    </div>

    <!-- Success step -->
    <div id="step-success" class="success">
        <div class="check">&#10003;</div>
        <h2>Installatie voltooid!</h2>
        <p>Open Field Studio is klaar voor gebruik.</p>
        <button class="btn btn-primary" onclick="OpenApp" style="margin-top:20px;">Open de app</button>
    </div>
</div>

<div class="footer">Open Field Studio v2.0 &middot; CC BY-SA 4.0</div>
</body>
</html>
